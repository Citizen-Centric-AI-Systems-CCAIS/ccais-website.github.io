---
import Nav, { menu } from '../components/Nav.astro';
import Socials from '../components/Socials.astro';
import RecognitionLogo from '../components/RecognitionLogo.astro';
import HeaderIcons from '../components/HeaderIcons.astro';
import siteAssets from '../data/site-assets.json';
import '../styles/fonts.css';
import '../styles/theme.css';
import '../styles/supplement.css';

// Footer menu is laid out as flex columns (each <ul> is one column).
const footerColumns = [
  ['About us', 'Projects'],
  ['News', 'Outputs'],
  ['Engage with us', 'Contact']
].map((labels) =>
  menu
    .filter((m) => labels.includes(m.label))
    .map((m) => {
      // "About us" acts as the link to /about-us/ in the footer, so the
      // duplicate "About CCAIS" child is dropped there.
      if (m.label === 'About us') {
        return { ...m, href: '/about-us/', children: m.children.filter((c) => c.href !== '/about-us/') };
      }
      return m;
    })
);

const footerStyle = siteAssets.footerBackground
  ? `background-image:url('${siteAssets.footerBackground}')`
  : undefined;

const {
  title = 'Citizen-Centric Artificial Intelligence Systems',
  description = 'We conduct fundamental research into citizen-centric artificial intelligence systems',
  bodyClass = ''
} = Astro.props;

const fullTitle = title.includes('Citizen-Centric')
  ? title
  : `${title} - Citizen-Centric Artificial Intelligence Systems`;
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="apple-touch-icon" sizes="180x180" href="/wp-content/themes/ccais/img/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/wp-content/themes/ccais/img/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/wp-content/themes/ccais/img/favicon/favicon-16x16.png" />
    <link rel="manifest" href="/wp-content/themes/ccais/img/favicon/site.webmanifest" />
    <meta name="msapplication-TileColor" content="#da532c" />
    <meta property="og:site_name" content="Citizen-Centric Artificial Intelligence Systems" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_GB" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- Poppins is self-hosted (SIL OFL 1.1); @font-face in src/styles/fonts.css. -->
    <link rel="preload" href="/fonts/poppins/poppins-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class={bodyClass}>
    <a class="skip-link screen-reader-text" href="#primary">Skip to content</a>

    <header class="site-header main-scroll-fixed-mobile">
      <div class="top-wrap" id="newsletter-bar">
        <div class="container">
          <p>Sign up to our newsletter</p>
          <!-- Replace the form action with your newsletter provider endpoint
               (e.g. Mailchimp / Buttondown). -->
          <form id="gform_1" method="post" action="#" aria-label="Newsletter signup">
            <label for="newsletter-email">Email</label>
            <input type="email" id="newsletter-email" name="email" placeholder="Email" required />
            <button type="submit" id="gform_submit_button_1">Sign up</button>
          </form>
        </div>
        <button class="close-signup" aria-label="Close newsletter signup">X</button>
      </div>

      <nav id="site-navigation" class="main-navigation">
        <div class="container">
          <a class="desktop-logo" href="/" aria-label="CCAIS home">
            <img src="/wp-content/uploads/2023/09/CCAIS-logo-colour.svg" alt="CCAIS - Citizen-Centric AI Systems" width="351" height="57" />
          </a>
          <a class="desktop-logo dark-logo" href="/" aria-label="CCAIS home">
            <img src="/wp-content/uploads/2024/01/CCAIS-logo-white.svg" alt="CCAIS - Citizen-Centric AI Systems" width="351" height="57" />
          </a>
          <a class="mobile-logo" href="/" aria-label="CCAIS home">
            <img src="/wp-content/uploads/2024/01/CCAIS-logo-white.svg" alt="CCAIS" width="200" height="45" />
          </a>
          <a class="mobile-fixed-logo" href="/" aria-label="CCAIS home" style="display:none">
            <img src="/wp-content/uploads/2023/10/fixed-logo.svg" alt="CCAIS" width="50" height="50" />
          </a>

          <div class="menu-overlay">
            <div class="mobile-top-block">
              <a class="mobile-logo" href="/"><img src="/wp-content/uploads/2023/10/CCAIS-logo-stack-white.svg" alt="CCAIS" width="120" height="90" /></a>
            </div>
            <div class="menu-main-menu-container">
              <Nav id="primary-menu" />
            </div>
            <div class="header-bottom-block">
              <HeaderIcons />
            </div>
          </div>

          <button class="mobile-search header-search-icon" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#ffffff"><path d="M23.7 22.3 17 15.6a9.4 9.4 0 1 0-1.4 1.4l6.7 6.7a1 1 0 0 0 1.4-1.4ZM9.5 17a7.5 7.5 0 1 1 7.5-7.5A7.5 7.5 0 0 1 9.5 17Z"/></svg>
          </button>

          <button class="menu-toggle" aria-controls="primary-menu" aria-expanded="false" aria-label="Menu">
            <span class="bar1"></span><span class="bar2"></span><span class="bar3"></span>
          </button>
        </div>
      </nav>

      <div class="header-search-backdrop" hidden>
        <button class="header-search-close" aria-label="Close search">×</button>
        <div class="header-search-form">
          <h2>Search</h2>
          <form class="search-form" action="/search/" method="get" role="search">
            <label for="header-search-field" class="screen-reader-text">Search for:</label>
            <input type="search" id="header-search-field" class="search-field" name="q" placeholder="Search for:" />
            <input type="submit" class="search-submit" value="Search" />
          </form>
        </div>
      </div>
    </header>

    <!-- Slide-in fixed header (desktop), shown after scrolling -->
    <div class="fixed-header">
      <nav class="main-navigation">
        <div class="container">
          <a class="desktop-logo" href="/" aria-label="CCAIS home">
            <img src="/wp-content/uploads/2023/10/fixed-logo.svg" alt="CCAIS" width="50" height="50" />
          </a>
          <div class="menu-overlay">
            <div class="menu-main-menu-container">
              <Nav id="fixed-menu" />
            </div>
            <div class="header-bottom-block">
              <HeaderIcons darkToggle={false} />
            </div>
          </div>
        </div>
      </nav>
    </div>

    <div id="content" class="site-content">
      <main id="primary" class="site-main">
        <slot />
      </main>
    </div>

    <div class="footer-newsletter-wrap">
      <div class="container">
        <p>Sign up to our newsletter</p>
        <form id="gform_1" method="post" action="#" aria-label="Newsletter signup">
          <label for="footer-newsletter-email">Email</label>
          <input type="email" id="footer-newsletter-email" name="email" placeholder="Email" required />
          <button type="submit" id="gform_submit_button_1">Sign up</button>
        </form>
      </div>
    </div>

    <footer class="site-footer" style={footerStyle}>
      <div class="footer-bg-image-overlay"></div>
      <div class="container">
        <div class="footer-wrap">
          <div class="footer-left-block">
            <div class="footer-logo">
              <a href="/"><img src="/wp-content/uploads/2023/10/CCAIS-logo-stack-white.svg" alt="CCAIS - Citizen-Centric AI Systems" width="110" height="84" /></a>
            </div>
            <div>
              <img src="/wp-content/uploads/2023/10/UoS-logo-white.svg" alt="University of Southampton" width="220" height="47" />
            </div>
          </div>

          <div class="footer-right-block">
            {footerColumns.map((col, i) => (
              <div class={`footer-menu-${['one', 'two', 'three'][i]}`}>
                <ul class="menu">
                  {col.map((item) => (
                    <li class={item.children ? 'menu-item menu-item-has-children' : 'menu-item'}>
                      <a href={item.children ? item.children[0].href : item.href}>{item.label}</a>
                      {item.children && (
                        <ul class="sub-menu">
                          {item.children.map((c) => (
                            <li class="menu-item"><a href={c.href}>{c.label}</a></li>
                          ))}
                        </ul>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            ))}

            <div class="footer-contact-block">
              <p>Contact</p>
              <p>Professor Sebastian Stein</p>
              <a href="mailto:ss2@ecs.soton.ac.uk">ss2@ecs.soton.ac.uk</a>
              <a href="tel:+442380597645">+44 (0)23 8059 7645</a>
              <Socials youtube />
            </div>
          </div>
        </div>

        <div class="site-info">
          <div class="left">
            <p>
              © {new Date().getFullYear()} Citizen-Centric AI Systems. Site made by
              <a href="https://www.recognitioncreative.com/" target="_blank"><RecognitionLogo /></a><br />
              Agents, Interaction and Complexity Research Group, University of Southampton
            </p>
          </div>
          <div class="right">
            <p>
              Funding by:<br />
              <a href="https://www.ukri.org/"><img src="/wp-content/uploads/2023/10/UKRI-logo-white.svg" alt="UKRI" width="160" height="50" /></a>
            </p>
          </div>
        </div>
      </div>
    </footer>

    <script src="../scripts/site.js"></script>
  </body>
</html>
