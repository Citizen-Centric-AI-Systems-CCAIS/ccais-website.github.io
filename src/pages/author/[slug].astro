---
import Base from '../../layouts/Base.astro';
import { team } from '../../data/team';
import { getCollection } from 'astro:content';
import { clip, personSchema } from '../../lib/seo';

export async function getStaticPaths() {
  return team.map((member) => ({ params: { slug: member.slug }, props: { member } }));
}
const { member } = Astro.props;
// Normalise the person's links (website + optional websites list) to
// { label, url } and de-duplicate by URL.
const seenUrls = new Set<string>();
const websites = (member.websites ?? [])
  .map((w: any) => (typeof w === 'string' ? { url: w, label: w } : { url: w.url, label: w.label ?? w.url }))
  .filter((w: { url: string }) => w.url && !seenUrls.has(w.url) && seenUrls.add(w.url));

// Everything this person authored (via `author:` in the entry frontmatter)
const sources = [
  { coll: 'projects', label: 'Project', base: '/projects/' },
  { coll: 'blog', label: 'Blog', base: '/uncategorised/' },
  { coll: 'news', label: 'News', base: '/latest-news/' },
  { coll: 'events', label: 'Event', base: '/events/' }
] as const;
const works = (
  await Promise.all(
    sources.map(async ({ coll, label, base }) =>
      (await getCollection(coll, (e) => e.data.author === member.slug || (e.data.members ?? []).includes(member.slug))).map((e) => ({
        label,
        title: e.data.title,
        image: e.data.image,
        url: `${base}${e.id}/`,
        date: e.data.date
      }))
    )
  )
).flat().sort((a, b) => b.date - a.date);

const bioText = (member.biography ?? '').replace(/\s*\n+\s*/g, ' ').trim();
const description = bioText
  ? clip(bioText)
  : `${member.name} — ${member.role}, Citizen-Centric AI Systems, University of Southampton.`;
const jsonld = personSchema({
  name: member.name,
  role: member.role,
  bio: bioText || undefined,
  image: member.photo,
  path: Astro.url.pathname,
  sameAs: websites.map((w) => w.url)
});
---
<Base title={member.name} description={description} image={member.photo} ogType="profile" jsonld={jsonld}>
  <div class="container author-page">
    <div class="page-intro">
      <p class="breadcrumb"><a href="/about-us/our-team/">Our team</a>/</p>
      <h1>{member.name}</h1>
      <p class="author-role">{member.role}</p>
    </div>

    <div class="author-layout">
      <div class="author-photo">
        <img src={member.photo} alt={member.name} width="300" height="300" />
      </div>
      <div class="author-details">
        {member.email && (
          <>
            <h4>Email:</h4>
            <p><a href={`mailto:${member.email}`}>{member.email}</a></p>
          </>
        )}
        {websites.length > 0 && (
          <>
            <h4>{websites.length > 1 ? 'Websites:' : 'Website:'}</h4>
            {websites.map((w) => <p><a href={w.url} target="_blank" rel="noopener">{w.label}</a></p>)}
          </>
        )}
        {member.biography && (
          <>
            <h4>Biography:</h4>
            {member.biography.split('\n').filter(Boolean).map((p: string) => <p>{p}</p>)}
          </>
        )}
      </div>
    </div>

    {works.length > 0 && (
      <section class="author-works">
        <h3>Projects &amp; Blogs:</h3>
        <div class="author-works-grid">
          {works.map((w) => (
            <div class="work-card">
              <div class="bg-image" style={w.image ? `background-image:url('${w.image}')` : undefined}></div>
              <a href={w.url}>
                <div class="text-overlay">
                  <span class="work-label">{w.label}</span>
                  <span class="work-title">{w.title}</span>
                </div>
              </a>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</Base>
