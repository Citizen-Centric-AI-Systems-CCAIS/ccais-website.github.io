---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { excerptOf } from '../../lib/excerpt';
const items = (await getCollection('projects')).sort((a, b) => b.data.date - a.data.date);
const trim = (s, n = 110) => (s && s.length > n ? s.slice(0, n) + '…' : s);
const fmt = (d) => d.toDateString();
---
<Base title="Projects" bodyClass="archive post-type-archive post-type-archive-projects">
  <div class="container">
    <h1>Projects</h1>
    <h4>Explore our current research projects</h4>
    <div class="projects">
      {items.map((i) => (
        <div class="single-project">
          <div class={`bg-image${i.data.image ? '' : ' no-image'}`} style={i.data.image ? `background-image:url('${i.data.image}')` : undefined}></div>
          <a href={`/projects/${i.id}/`}>
            <div class="text-overlay">
              <h3>{i.data.title}</h3>
              <p>{trim(excerptOf(i))}</p>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</Base>
