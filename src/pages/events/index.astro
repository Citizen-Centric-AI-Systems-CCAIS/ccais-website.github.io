---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { excerptOf } from '../../lib/excerpt';
const items = (await getCollection('events')).sort((a, b) => b.data.date - a.data.date);
const trim = (s, n = 110) => (s && s.length > n ? s.slice(0, n) + '…' : s);
const fmt = (d) => d.toDateString();
---
<Base title="Events" description="Events, workshops and talks hosted or attended by the CCAIS group on citizen-centric artificial intelligence." bodyClass="archive post-type-archive post-type-archive-events">
  <div class="container">
    <h1>Events</h1>
    <h4>Workshops and events organised by CCAIS</h4>
    <div class="events-wrapper">
      {items.map((i) => (
        <div class="single-events">
          <div class="bg-image" style={`background-image:url('${i.data.image}')`}></div>
          <a href={`/events/${i.id}/`}>
            <div class="text-overlay">
              <h3>{i.data.title}</h3>
              <p>{trim(excerptOf(i))}</p>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</Base>
