---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/sections/Hero.astro';
import OneColumn from '../../components/sections/OneColumn.astro';

const partners = [
  { name: 'Connected Places Catapult', bg: 'catapult-image.png', logo: 'catapult.png', url: 'https://cp.catapult.org.uk/', text: 'The UK’s innovation accelerator for cities, transport & place leadership.' },
  { name: 'Dstl', bg: 'dstl-image.png', logo: 'dstl.png', url: 'https://www.gov.uk/government/organisations/defence-science-and-technology-laboratory', text: 'The Defence Science and Technology Laboratory (Dstl) is the science inside UK defence and security.' },
  { name: 'EA Technology', bg: 'ea-image.png', logo: 'ea.svg', url: 'https://eatechnology.com/', text: 'To promote the development of resilient, accessible, low cost energy networks globally, accelerating the transition to energy decarbonisation.' },
  { name: 'Energy Systems Catapult', bg: 'catapul-energy-image-2.jpg', logo: 'catapult-energy.svg', url: 'https://es.catapult.org.uk/', text: 'We help home energy innovators grow fast… delivering peerless real-world testing, and driving skills and investment for zero-carbon homes.' },
  { name: 'Fawley Waterside', bg: 'fawley-image.png', logo: 'fawley.svg', url: 'https://fawleywaterside.co.uk/', text: 'With an unparalleled location in the New Forest National Park, with two miles of coastline, Fawley Waterside will be one of the most beautiful new towns in England.' },
  { name: 'IBM Research', bg: 'ibm-image.png', logo: 'ibm.png', url: 'https://research.ibm.com/', text: 'IBM Research is the largest industrial research organization in the world.' },
  { name: 'Jaguar Land Rover', bg: 'jag-image.png', logo: 'jag-land-rover.png', url: 'https://www.jaguarlandrover.com/', text: 'It is our strategy to realise our vision to be proud creators of the most desirable, modern luxury brands, for the most discerning of clients.' },
  { name: 'Siemens Mobility', bg: 'siemens-image.png', logo: 'siemens.png', url: 'https://www.mobility.siemens.com/global/en.html', text: 'As a leader in transport solutions, we shape connected mobility. The mobility environment is being shaped by three megatrends: climate change, population growth and digitalization.' },
  { name: 'Thales', bg: 'thales-image.png', logo: 'thales.png', url: 'https://www.thalesgroup.com/en', text: 'Thales is investing in digital and “deep tech” innovations – Big Data, artificial intelligence, connectivity, cybersecurity and quantum technology – to build a future we can all trust.' },
  { name: 'UTU Technologies', bg: 'utu-image.png', logo: 'utu.png', url: 'https://utu.io/', text: 'Building a more human-friendly internet. UTU means “humanity” in Swahili. Our name reminds us of our company’s roots in Kenya and our vision of a safer, more trusted digital world built around relationships, like the real world.' }
];
const up = (f: string) => `/wp-content/uploads/2023/11/${f}`;
---
<Base title="Our partners">
  <Hero title="Our partners" breadcrumb="About us/" image="/wp-content/uploads/2023/11/AG-CCAIS-Workshop-068-resize-edit2-scaled.jpg" />

  <OneColumn>
    <h4><span style="color: #450dc0">This fellowship is supported by a range of industrial stakeholders that will work closely with the research team both on the broad research challenges and on specific applications. These partners include:</span></h4>
  </OneColumn>

  <div class="partners-section">
    <div class="container">
      <div class="small-container">
        {partners.map((p) => (
          <div class="partner-block">
            <div class="bg-image" style={`background-image:url(${up(p.bg)});`}>
              <div class="overlay"></div>
              <img src={up(p.logo)} alt={p.name} loading="lazy" />
            </div>
            <div class="text">
              <h3><span style="color: #450dc0">{p.name}</span></h3>
              <p>{p.text}</p>
              <a href={p.url} target="_blank" class="customButton button-primary" aria-label="Find out more">Find out more</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

</Base>
