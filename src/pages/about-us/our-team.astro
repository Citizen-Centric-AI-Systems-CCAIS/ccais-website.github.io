---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/sections/Hero.astro';
import { team, groups } from '../../data/team';
---
<Base title="Our team">
  <Hero title="Our team" breadcrumb="About us/" image="/wp-content/uploads/2023/11/ccais-team-shot-1.jpg" />

  {groups.map((g) => (
    <div class={`page-team-section ${g.variant}`}>
      <div class="container">
        <h2>{g.heading}</h2>
        <div class="teams-block">
          {team.filter((m) => m.group === g.heading).map((m) => (
            <div class="team-block">
              <a href={`/author/${m.slug}/`}>
                <img src={m.photo} alt={m.name} loading="lazy" width="300" height="300" />
                <div class="text">
                  <h4>{m.name}</h4>
                  <p>{m.role}</p>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  ))}
</Base>
