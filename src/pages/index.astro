---
import Base from '../layouts/Base.astro';
import Socials from '../components/Socials.astro';
import LinkedInFeed from '../components/LinkedInFeed.astro';
import siteAssets from '../data/site-assets.json';
import { getCollection } from 'astro:content';
import { excerptOf } from '../lib/excerpt';

const byDate = (a, b) => b.data.date - a.data.date;
const projects = (await getCollection('projects')).sort(byDate).slice(0, 3);
const news = (await getCollection('news')).sort(byDate).slice(0, 2);
const blog = (await getCollection('blog')).sort(byDate).slice(0, 2);
const events = (await getCollection('events')).sort((a, b) => a.data.eventDate - b.data.eventDate);

const fmtCard = (d) => d.toDateString(); // e.g. "Wed Feb 25 2026" (as on the WP site)
const fmtEvent = (d) =>
  `${String(d.getDate()).padStart(2, '0')} ${d.toLocaleDateString('en-GB', { month: 'short' })}, ${d.getFullYear()}`;
const trim = (s, n = 90) => (s && s.length > n ? s.slice(0, n) + '…' : s);
---
<Base description="A University of Southampton research group, led by Professor Sebastian Stein, developing the fundamental science to build AI systems that citizens can trust." bodyClass="home page-template-front-page">
  <section class="video-section">
    <div class="container">
      <div class="video-block">
      <video id="hero_video" autoplay muted loop playsinline>
        <source src="/wp-content/uploads/2024/02/southampton_ccai_web_edit-1080p.mp4" type="video/mp4" />
        Your browser does not support the video tag.
      </video>
      <div class="overlay"></div>
      <h2>Putting people at the centre of artificial intelligence systems</h2>
        <button class="pause-bt" aria-label="Pause video">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#ffffff"><path d="M7 4h3v16H7zM14 4h3v16h-3z"/></svg>
        </button>
      </div>
    </div>
  </section>

  <section class="intro-bar-section">
    <div class="container">
      <div class="box">
        <div class="text">
          <h3>Citizen-Centric AI Systems</h3>
          <p>
            This 5-year UKRI Turing AI Acceleration Fellowship led by Professor Sebastian Stein is
            developing the fundamental science needed to build artificial intelligence (AI) systems
            that can be trusted by citizen users.
          </p>
        </div>
        <div class="links">
          <div class="box-one">
            <div class="bg-image" style="background-image:url('/wp-content/uploads/2023/11/child-with-robot-1.jpg')"></div>
            <a class="button" href="/about-us/vision/"><h4>Our Vision</h4></a>
          </div>
          <div class="box-two">
            <div class="bg-image" style="background-image:url('/wp-content/uploads/2023/10/AG-Seb-Stein-Team-Working-25-resize.jpg')"></div>
            <a class="button" href="/about-us/"><h4>Research challenges</h4></a>
          </div>
          <div class="box-three">
            <div class="bg-image" style="background-image:url('/wp-content/uploads/2023/11/firemen-resize.jpg')"></div>
            <a class="button" href="/about-us/applications/"><h4>Applications</h4></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="who-we-are-section">
    <div class="container">
      <div class="wwab">
        <div class="one">
          <img src="/wp-content/uploads/2023/11/AG-Seb-Stein-01-med.jpg" alt="Prof Sebastian Stein" loading="lazy" />
          <h5>Prof Sebastian Stein</h5>
          <p>Principal Investigator,<br />Citizen-Centric AI Systems</p>
        </div>
        <div class="two">
          <h4>
            Artificial intelligence holds tremendous promise in addressing critical societal
            challenges, from climate change and air pollution to dealing with natural disasters
            and improving our quality of life.
          </h4>
          <p>
            However, the benefits of AI can only be realised if citizen end users are able to
            trust future AI systems. To achieve this trust, we need to include citizens closely
            in the design and in the operation of those systems.
          </p>
        </div>
        <div class="three">
          {siteAssets.wwabVideo && (
            <div class="video">
              <img
                class="video__placeholder"
                src="/wp-content/uploads/2024/05/yotube-video-thumbnail-1-scaled.jpg"
                alt="Watch the Citizen-Centric AI Systems video"
                data-video={siteAssets.wwabVideo}
                loading="lazy"
              />
              <button class="video__button" aria-label="Play video"></button>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="team-section">
    <div class="container">
      <div class="top-block">
        <h2>Meet the team</h2>
        <a class="button" href="/about-us/our-team/">Our team</a>
      </div>
      <div class="main-block">
        <div class="left">
          <img src="/wp-content/uploads/2024/02/AG-CCAIS-Team-crop-1.jpg" alt="The CCAIS team" loading="lazy" />
        </div>
        <div class="right">
          <p>
            <strong>We are a diverse team of researchers based in the School of Electronics and
            Computer Science at the University of Southampton, UK.</strong>
          </p>
          <p>
            Representing different backgrounds, career paths and career stages, we work together
            to develop the fundamental science underpinning citizen-centric AI.
          </p>
          <p>
            Given that AI is starting to pervade all aspects of our lives, we recognise that a
            multidisciplinary approach is essential, and we use a wide range of techniques from
            computer science, AI, mathematics and economics. We also collaborate closely with
            social scientists, legal scholars, civil engineers and transportation scientists.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="projects-section">
    <div class="container">
      <div class="top-block">
        <h2>Our current projects</h2>
        <a class="button" href="/projects/">View all</a>
      </div>
      <div class="projects-main-block">
        {projects.map((p) => (
          <div class="single-project">
            <div class={`bg-image${p.data.image ? '' : ' no-image'}`} style={p.data.image ? `background-image:url('${p.data.image}')` : undefined}></div>
            <a href={`/projects/${p.id}/`}>
              <div class="text-overlay">
                <h3>{p.data.title}</h3>
                <p>{trim(excerptOf(p))}</p>
              </div>
            </a>
          </div>
        ))}
      </div>
      <p class="swipe-text">Swipe</p>
    </div>
  </section>

  <section class="news-blog-section">
    <div class="container">
      <div class="news-block">
        <div class="top-block">
          <h2>Our latest news</h2>
          <a class="button" href="/latest-news/">View all</a>
        </div>
        <div class="news-main-block">
          {news.map((n) => (
            <div class="single-news">
              <div class={`bg-image${n.data.image ? '' : ' no-image'}`} style={n.data.image ? `background-image:url('${n.data.image}')` : undefined}></div>
              <div class="overlay"></div>
              <a href={`/latest-news/${n.id}/`}>
                <div class="text-overlay">
                  <h3>{n.data.title}</h3>
                  <span>{fmtCard(n.data.date)}</span>
                </div>
              </a>
            </div>
          ))}
        </div>
        <p class="swipe-text">Swipe</p>
      </div>

      <div class="blog-block">
        <div class="top-block">
          <h2>Our latest blog posts</h2>
          <a class="button" href="/blog/">View all</a>
        </div>
        <div class="blog-main-block">
          {blog.map((b) => (
            <div class="single-blog">
              <div class={`bg-image${b.data.image ? '' : ' no-image'}`} style={b.data.image ? `background-image:url('${b.data.image}')` : undefined}></div>
              <div class="overlay"></div>
              <a href={`/uncategorised/${b.id}/`}>
                <div class="text-overlay">
                  <h3>{b.data.title}</h3>
                  <span>{fmtCard(b.data.date)}</span>
                </div>
              </a>
            </div>
          ))}
        </div>
        <p class="swipe-text">Swipe</p>
      </div>
    </div>
  </section>

  <section class="events-section">
    <div class="container">
      <div class="top-block">
        <h2>CCAIS events</h2>
        <a class="button" href="/events/">View all</a>
      </div>
      <div class="evernts-wrapper">
        <div class="events-main-block">
          {events.map((e) => (
            <div class="single-event">
              <div class="date">{fmtEvent(e.data.eventDate)}</div>
              <div>
                <h3>{e.data.title}</h3>
                <p>{trim(excerptOf(e), 220)}</p>
                <a href={`/events/${e.id}/`}>View event</a>
              </div>
            </div>
          ))}
        </div>
        <p class="swipe-text">Swipe</p>
      </div>
    </div>
  </section>

  <section class="social-section">
    <div class="container">
      <div class="top-block">
        <h2>Our socials</h2>
        <div class="icons">
          <Socials youtube />
        </div>
      </div>
      <div class="social-main-block">
        <LinkedInFeed limit={4} />
        <p>
          Follow CCAIS on <a href="https://www.linkedin.com/company/ccais/">LinkedIn</a> and
          <a href="https://www.youtube.com/@CCAIS_Soton">YouTube</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="accolades-section">
    <div class="container">
      <div class="top-block">
        <h2>Our achievements</h2>
        <a href="/about-us/">Find out more</a>
      </div>
      <div class="accolades-main-block">
        <div class="item">
          <img src="/wp-content/uploads/2023/12/Paper-Icon.svg" alt="" loading="lazy" />
          <h3>80+ Papers</h3>
        </div>
        <div class="item">
          <img src="/wp-content/uploads/2023/12/Lectern.svg" alt="" loading="lazy" />
          <h3>5+ Keynotes</h3>
        </div>
        <div class="item">
          <img src="/wp-content/uploads/2023/12/Talks.svg" alt="" loading="lazy" />
          <h3>30+ Invited Talks</h3>
        </div>
        <div class="item">
          <img src="/wp-content/uploads/2023/12/Workshop.svg" alt="" loading="lazy" />
          <h3>20+ Workshops</h3>
        </div>
      </div>
      <p class="swipe-text">Swipe</p>
    </div>
  </section>
</Base>
