---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { excerptOf } from '../../lib/excerpt';
const items = (await getCollection('news')).sort((a, b) => b.data.date - a.data.date);
const trim = (s, n = 110) => (s && s.length > n ? s.slice(0, n) + '…' : s);
const fmt = (d) => d.toDateString();
---
<Base title="Latest News" description="News from the CCAIS group — papers, awards, events and milestones in citizen-centric AI research at the University of Southampton." bodyClass="archive post-type-archive post-type-archive-latest-news">
  <div class="container">
    <h1>Latest News</h1>
    <h4>News and updates from the CCAIS team</h4>
    <div class="latest-news">
      {items.map((i) => (
        <div class="single-news">
          <div class={`bg-image${i.data.image ? '' : ' no-image'}`} style={i.data.image ? `background-image:url('${i.data.image}')` : undefined}></div>
          <a href={`/latest-news/${i.id}/`}>
              <span class="date">{fmt(i.data.date)}</span>
            <div class="text-overlay">
              <h3>{i.data.title}</h3>
              <p>{trim(excerptOf(i))}</p>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</Base>
