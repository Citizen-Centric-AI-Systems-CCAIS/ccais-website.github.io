---
// Search / X / LinkedIn / dark-mode cluster shown at the right of the nav.
const { darkToggle = true } = Astro.props;
---
<button class="header-search-icon header-search-desktop" aria-label="Search">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"><path d="M23.7 22.3 17 15.6a9.4 9.4 0 1 0-1.4 1.4l6.7 6.7a1 1 0 0 0 1.4-1.4ZM9.5 17a7.5 7.5 0 1 1 7.5-7.5A7.5 7.5 0 0 1 9.5 17Z"/></svg>
</button>
<a href="https://www.linkedin.com/company/ccais/" aria-label="CCAIS on LinkedIn">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.46zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"/></svg>
</a>
{darkToggle && (
  <button class="dark-mode-toggle" aria-label="Toggle dark mode">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 18V4a8 8 0 0 1 0 16Z"/></svg>
  </button>
)}
